# ============================================
# Variables de entorno para Docker Compose
# Copia este archivo como .env y completa los valores
# ============================================

# Contraseña de SQL Server SA (mínimo 8 caracteres, debe incluir mayúsculas, minúsculas, números y símbolos)
SA_PASSWORD=TuContraseñaSegura123!

# Clave secreta para firmar tokens JWT (mínimo 32 caracteres)
JWT_KEY=TuClaveJWT-MinimoTreintaYDosCaracteres!!

# Orígenes permitidos por CORS (separados por coma si son varios)
CORS_ORIGINS=http://localhost:4200,http://localhost:4201
