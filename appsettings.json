{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    // Configuracion inicial (SQL Server), se deja comentada como referencia:
    // "conexion": "Server=JOHAN\\SQLEXPRESS;Database=HoneyBalanceDB;Integrated Security=true;TrustServerCertificate=True"
    // Configuracion actual (NeonDB/PostgreSQL): definir por user-secrets o variable de entorno.
    "conexion": "CONFIGURE_VIA_USER_SECRETS_OR_ENVIRONMENT_VARIABLE"
  },
  "Jwt": {
    "Issuer": "HoneyBack",
    "Audience": "HoneyBack",
    "ExpiresInMinutes": 60
  },
  "Cors": {
    "AllowedOrigins": ["http://localhost:4200", "http://localhost:4201"]
  },
  "Google": {
    "ClientId": "CONFIGURE_VIA_USER_SECRETS_OR_ENVIRONMENT_VARIABLE"
  }
}
