# Variables compartidas
JWT_KEY=TuClaveJWT-MinimoTreintaYDosCaracteres!!
JWT_ISSUER=HoneyBack
JWT_AUDIENCE=HoneyBack
JWT_EXPIRES_MINUTES=60

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:4201,http://localhost:3000

# Frontend (solo requerido para compose.dev.yml cuando se construye la imagen local)
# Ejemplo (PowerShell): C:/Users/<usuario>/Desktop/honeybalance/honeybalance-angular
HONEYBALANCE_FRONTEND_CONTEXT=
HONEYBALANCE_FRONTEND_DOCKERFILE=Dockerfile

# Imagenes para compose.prod.yml
HONEYBACK_API_IMAGE=ghcr.io/tu-org/honeyback-api:1.0.0
HONEYBALANCE_WEB_IMAGE=ghcr.io/tu-org/honeybalance-web:1.0.0
HONEYANALYTICS_IMAGE=ghcr.io/tu-org/honeybalance-analytics:1.0.0

# Base de datos NeonDB (PostgreSQL)
# Usar el endpoint POOLED (no el directo) para evitar cold-starts
# API .NET (Npgsql): postgresql://user:pass@pooler.neon.tech/dbname
API_DATABASE_URL=postgresql://usuario:password@pooler.neon.tech/honeybalance
# Microservicio analíticas (SQLAlchemy asyncpg): postgresql+asyncpg://user:pass@pooler.neon.tech/dbname
ANALYTICS_DATABASE_URL=postgresql+asyncpg://usuario:password@pooler.neon.tech/honeybalance

# Flags de runtime
SWAGGER_ENABLED=true
APPLY_MIGRATIONS_AT_STARTUP=true
ASPNETCORE_ENVIRONMENT=Docker
