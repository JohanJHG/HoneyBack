# Variables compartidas
JWT_KEY=TuClaveJWT
JWT_ISSUER=HoneyBack
JWT_AUDIENCE=HoneyBack
JWT_EXPIRES_MINUTES=60

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:4201,http://localhost:3000

# Frontend: ruta absoluta al repositorio del frontend en tu maquina
# Windows (PowerShell): C:/Users/<usuario>/ruta/honeybalance-angular
# macOS / Linux:        /Users/<usuario>/ruta/honeybalance-angular
HONEYBALANCE_FRONTEND_CONTEXT=
HONEYBALANCE_FRONTEND_DOCKERFILE=Dockerfile

# Imagenes para compose.prod.yml (no aplica en desarrollo local)
HONEYBACK_API_IMAGE=ghcr.io/tu-org/honeyback-api:1.0.0
HONEYBALANCE_WEB_IMAGE=ghcr.io/tu-org/honeybalance-web:1.0.0
HONEYANALYTICS_IMAGE=ghcr.io/tu-org/honeybalance-analytics:1.0.0

# Base de datos — OPCION A: base de datos local con Docker (compose.local.yml)
# No requiere cambios. La conexion esta embebida en compose.local.yml.

# Base de datos — OPCION B: base de datos externa NeonDB / DigitalOcean (compose.dev.yml)
# API .NET (Npgsql):
API_DATABASE_URL=postgresql://usuario:password@host:5432/honeybalance?sslmode=require
# Microservicio analiticas (SQLAlchemy asyncpg):
ANALYTICS_DATABASE_URL=postgresql+asyncpg://usuario:password@host:5432/honeybalance

# Email con Resend (opcional en desarrollo, los emails se omiten si no se configura)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@honeybalance.online
RESEND_FROM_NAME=HoneyBalance

# Flags de runtime
SWAGGER_ENABLED=true
APPLY_MIGRATIONS_AT_STARTUP=true
ASPNETCORE_ENVIRONMENT=Docker
